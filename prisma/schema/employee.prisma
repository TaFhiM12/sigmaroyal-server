model Employee {
    id              String   @id @default(cuid())
    name            String   @db.VarChar()
    designation     String   @db.VarChar(150)
    department      String   @db.VarChar(150)
    bio             String   @db.Text
    photoUrl        String
    phone           String?
    email           String?  @unique
    isActive        Boolean  @default(true)
    experienceYears Int?
    education       String?
    orderIndex      Int? 
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}
